{
  "name": "bizledger-backend",
  "version": "1.0.0",
  "description": "BizLedger API Server",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "db:push": "npx prisma db push",
    "db:generate": "npx prisma generate",
    "db:seed": "node src/seed.js",
    "db:studio": "npx prisma studio",
    "db:reset": "npx prisma db push --force-reset && node src/seed.js"
  },
  "dependencies": {
    "@prisma/client": "^5.10.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "express": "^4.18.3",
    "express-rate-limit": "^7.2.0",
    "jsonwebtoken": "^9.0.2",
    "prisma": "^5.10.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
